<?php CoreuiMenu::load(Menu::BACKEND, Session::get('perfil_id'));

// Cargar datos de la empresa
$empresaFile = PUBLIC_PATH . 'empresa/empresa.json';
$empresaNombre = 'DBKM';
$empresaLogo = null;
$empresaLogoMini = null;

if (file_exists($empresaFile)) {
    $empresaData = json_decode(file_get_contents($empresaFile), true);
    $empresaNombre = !empty($empresaData['nombre']) ? $empresaData['nombre'] : 'DBKM';
}

// Detectar logo
$logoExtensions = array('png', 'jpg', 'jpeg', 'svg');
foreach ($logoExtensions as $ext) {
    if (file_exists(PUBLIC_PATH . 'empresa/logo-empresa.' . $ext)) {
        $empresaLogo = PUBLIC_PATH . 'empresa/logo-empresa.' . $ext;
        break;
    }
}
foreach ($logoExtensions as $ext) {
    if (file_exists(PUBLIC_PATH . 'empresa/logo-mini.' . $ext)) {
        $empresaLogoMini = PUBLIC_PATH . 'empresa/logo-mini.' . $ext;
        break;
    }
}
?>
