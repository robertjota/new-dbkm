<?php CoreuiMenu::load(Menu::BACKEND, Session::get('perfil_id'));

// Cargar datos de la empresa desde config
$empresaData = Config::get('config.custom.empresa');
$empresaNombre = !empty($empresaData['nombre']) ? $empresaData['nombre'] : 'DBKM';
$empresaLogo = null;
$empresaLogoMini = null;

// Detectar logo
$basePath = dirname(APP_PATH) . '/public/empresa/';
$logoExtensions = array('png', 'jpg', 'jpeg', 'svg');
foreach ($logoExtensions as $ext) {
    if (file_exists($basePath . 'logo-empresa.' . $ext)) {
        $empresaLogo = '/empresa/logo-empresa.' . $ext;
        break;
    }
}
foreach ($logoExtensions as $ext) {
    if (file_exists($basePath . 'logo-mini.' . $ext)) {
        $empresaLogoMini = '/empresa/logo-mini.' . $ext;
        break;
    }
}
?>
<!--
        Agregar la clase smini-hide a un elemento lo hará invisible (opacidad: 0) cuando la barra lateral esté en modo mini

        Agregar la clase smini-show a un elemento lo hará visible (opacidad: 1) cuando la barra lateral esté en modo mini

        Si deseas deshabilitar la animación de transición, asegúrate de agregar también la clase no-transition a tu elemento

        Agregar la clase smini-hidden a un elemento lo ocultará cuando la barra lateral esté en modo mini

        Agregar la clase smini-visible a un elemento lo mostrará (display: inline-block) solo cuando la barra lateral esté en modo mini

        Agregar la clase smini-visible-block a un elemento lo mostrará (display: block) solo cuando la barra lateral esté en modo mini
-->

